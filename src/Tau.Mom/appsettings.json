{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Mom": {
    "InboxPath": "mom/inbox",
    "OutboxPath": "mom/outbox",
    "ArchivePath": "mom/archive",
    "EventsPath": "mom/events",
    "DefaultWorkingDirectory": ".",
    "Sandbox": "host",
    "DefaultProvider": "openai",
    "DefaultModel": "gpt-5.4",
    "SlackSocketModeEnabled": false,
    "SlackAppToken": null,
    "SlackBotToken": null,
    "SlackApiBaseUrl": "https://slack.com/api/",
    "SlackBackfillEnabled": true,
    "SlackBackfillMaxPages": 3,
    "SlackBackfillPageSize": 1000,
    "SlackChannelQueueLimit": 5,
    "SlackSocketModeReconnectDelaySeconds": 5,
    "PollIntervalSeconds": 5,
    "MaxFilesPerPoll": 8,
    "RunningStatusStaleAfterMinutes": 60
  }
}
